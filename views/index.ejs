<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mahfuj Mustafa - Resume</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Mono:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <canvas id="mesh-bg"></canvas>
    <div class="page">
        <div class="contact-info">
            <span class="line accent">(347) 844-4127</span>
            <span class="line accent">MAHFUJMUSTAFA527@GMAIL.COM</span>
            <span class="line">NEW YORK CITY, NY</span>
        </div>

        <%
            // circuit y offset — higher = lower
            const CO = 38;

            const pts = [
                { x: 30,  by: 30 },
                { x: 130, by: 15 },
                { x: 250, by: 30 },
                { x: 310, by: 18 },
                { x: 420, by: 25 },
                { x: 500, by: 15 },
                { x: 580, by: 31 },
                { x: 680, by: 15 },
                { x: 760, by: 30 },
                { x: 870, by: 23 },
                { x: 960, by: 32 },
            ];
            const nodes = pts.map(p => ({ x: p.x, y: p.by + CO }));

            const maskPoly = ['0,' + nodes[0].y]
                .concat(nodes.map(n => n.x + ',' + n.y))
                .concat(['1000,' + nodes[nodes.length-1].y, '1000,110', '0,110'])
                .join(' ');

            const lineOps = [0.5, 0.5, 0.5, 0.5, 0.5, 0.5, 0.5, 0.5, 0.5, 0.5];
            const dotR    = [3.5, 3, 4, 2.5, 3.5, 3, 3.5, 2.5, 3.5, 3, 2.5];
            const dotOps  = [0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7, 0.7];

            const stubs = [
                { from: 1, dx: 0,   dy: 16,  endDot: 2 },
                { from: 3, dx: 15,  dy: 14,  endDot: 1.5 },
                { from: 4, dx: 0,   dy: 14,  endDot: 2 },
                { from: 6, dx: -12, dy: 13,  endDot: 1.8 },
                { from: 8, dx: 0,   dy: 14,  endDot: 2 },
                { from: 9, dx: 14,  dy: 10,  endDot: 1.5 },
            ];

            const resolvedStubs = stubs.map(s => {
                const ox = nodes[s.from].x;
                const oy = nodes[s.from].y;
                return { x1: ox, y1: oy, x2: ox + s.dx, y2: oy + s.dy, endDot: s.endDot };
            });

            const tracePath = 'M ' + nodes.map(n => n.x + ' ' + n.y).join(' L ');
        %>

        <svg class="hero-title" viewBox="0 0 1000 110" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <mask id="name-mask">
                    <rect x="0" y="0" width="1000" height="110" fill="white"/>
                    <polygon points="<%= maskPoly %>" fill="black"/>
                </mask>

                <pattern id="pcb-grid" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
                    <circle cx="10" cy="10" r="0.6" fill="#e88aab" opacity="0.12"/>
                </pattern>

                <radialGradient id="glow-grad" cx="0.5" cy="0.5" r="0.5">
                    <stop offset="0%" stop-color="white"/>
                    <stop offset="100%" stop-color="black"/>
                </radialGradient>

                <mask id="glow-mask">
                    <rect id="glow-rect" x="0" y="0" width="200" height="200" fill="url(#glow-grad)" transform="translate(-9999, -9999)"/>
                    <rect id="pulse-glow-rect" x="0" y="0" width="160" height="160" fill="url(#glow-grad)" transform="translate(-9999, -9999)"/>
                    <polygon points="<%= maskPoly %>" fill="black"/>
                </mask>

                <filter id="pulse-glow" x="-50%" y="-50%" width="200%" height="200%">
                    <feGaussianBlur stdDeviation="3" result="blur"/>
                    <feMerge>
                        <feMergeNode in="blur"/>
                        <feMergeNode in="SourceGraphic"/>
                    </feMerge>
                </filter>

                <filter id="letterpress" x="-5%" y="-5%" width="110%" height="120%">
                    <feOffset dx="0" dy="3.5" in="SourceAlpha" result="off"/>
                    <feGaussianBlur stdDeviation="1" in="off" result="blur"/>
                    <feFlood flood-color="#000" flood-opacity="0.2" result="shadow"/>
                    <feComposite in="shadow" in2="blur" operator="in" result="inset"/>
                    <feMerge>
                        <feMergeNode in="SourceGraphic"/>
                        <feMergeNode in="inset"/>
                    </feMerge>
                </filter>
            </defs>

            <rect width="1000" height="110" fill="url(#pcb-grid)"/>

            <text x="500" y="65" text-anchor="middle" mask="url(#name-mask)"
                  font-family="'Roboto Mono', monospace" font-size="90" font-weight="700"
                  fill="#e6e6e6" letter-spacing="3" filter="url(#noise-texture)">MAHFUJ MUSTAFA</text>

            <text x="500" y="65" text-anchor="middle" mask="url(#glow-mask)"
                  font-family="'Roboto Mono', monospace" font-size="90" font-weight="700"
                  fill="#e87da3" letter-spacing="3" opacity="0.6" filter="url(#letterpress)">MAHFUJ MUSTAFA</text>


            <% for (let i = 0; i < nodes.length - 1; i++) { %>
            <line x1="<%= nodes[i].x %>" y1="<%= nodes[i].y %>" x2="<%= nodes[i+1].x %>" y2="<%= nodes[i+1].y %>" stroke="#e88aab" stroke-width="1" stroke-opacity="<%= lineOps[i] %>"/>
            <% } %>

            <% for (const stub of resolvedStubs) { %>
            <line x1="<%= stub.x1 %>" y1="<%= stub.y1 %>" x2="<%= stub.x2 %>" y2="<%= stub.y2 %>" stroke="#e88aab" stroke-width="0.6" stroke-opacity="0.12"/>
            <circle cx="<%= stub.x2 %>" cy="<%= stub.y2 %>" r="<%= stub.endDot %>" fill="#303030" stroke="#e88aab" stroke-width="0.4" stroke-opacity="0.15"/>
            <% } %>

            <circle id="pulse-dot" r="3" fill="#e88aab" filter="url(#pulse-glow)" opacity="0.9">
                <animateMotion dur="4s" repeatCount="indefinite" path="<%= tracePath %>"/>
                <animate attributeName="opacity" values="0.4;1;0.4" dur="1.5s" repeatCount="indefinite"/>
            </circle>

            <circle r="6" fill="none" stroke="#e88aab" stroke-width="0.8" opacity="0.3">
                <animateMotion dur="4s" repeatCount="indefinite" path="<%= tracePath %>"/>
                <animate attributeName="r" values="4;8;4" dur="1.5s" repeatCount="indefinite"/>
                <animate attributeName="opacity" values="0.3;0.1;0.3" dur="1.5s" repeatCount="indefinite"/>
            </circle>

            <% for (let i = 0; i < nodes.length; i++) { %>
            <circle cx="<%= nodes[i].x %>" cy="<%= nodes[i].y %>" r="<%= dotR[i] %>"
                    fill="#303030" stroke="#e88aab" stroke-width="0.7" stroke-opacity="<%= dotOps[i] %>"/>
            <% } %>
        </svg>

        <section>
            <h2>
                <span class="section-arrow">
                    <span class="pulse">></span>
                    <span>Skills</span>
                </span>
            </h2>
            <div class="grid">
                <div class="skills-group">
                    <span class="label">Technical Skills:</span> Python, Lua, JavaScript, REST API Design, WebSocket Programming, Discord API, Roblox Studio, Git, TinyDB, Reverse Engineering, Security Analysis, Server Performance Optimization, Debugging, Automation.
                </div>
                <div class="skills-group">
                    <span class="label">Development:</span> Full-stack Game Development, Bot Development, API Wrapper Design, Modular Architecture, Client-Server Systems, Live Operations Management.
                </div>
                <div class="skills-group">
                    <span class="label">Soft Skills:</span> Team Collaboration, Project Planning, Community Organizing, Youth Mentorship, Event Coordination, Volunteer Leadership.
                </div>
            </div>
        </section>

        <section>
            <h2>
                <span class="section-arrow">
                    <span class="pulse">></span>
                    <span>Experience</span>
                </span>
            </h2>
            <div class="grid">

            <div class="entry">
                <div class="entry-title-line">
                    <a class="entry-name" href="https://mergebox.net/" target="_blank">Merge Box</a>
                    <span class="entry-separator"> &mdash; </span>
                    <span class="entry-role">Programmer</span>
                </div>
                <div class="entry-date">FEBRUARY 2024 &ndash; PRESENT</div>
                <ul>
                    <li>Collaborating with a development team to maintain multiple games for consumer usage.</li>
                    <li>Handling weekly &ldquo;Live Ops&rdquo;, involving debugging and patching bugs, adding new mechanics, and organizing workspaces.</li>
                    <li>Running regular audits on games to maintain and improve server capabilities and performance.</li>
                    <li>Created and maintained multiple Roblox titles generating 78M+ player visits.</li>
                </ul>
            </div>

            <div class="entry">
                <div class="entry-title-line">
                    <a class="entry-name" href="https://muslimummah.org/" target="_blank">MUNA</a>,
                    <span class="entry-separator"> 330 E 106th St NY &mdash; </span>
                    <span class="entry-role">Associate Member</span>
                </div>
                <div class="entry-date">2022 &ndash; PRESENT</div>
                <ul>
                    <li>Volunteering under the Manhattan Youth Sub-Chapter.</li>
                    <li>Planning and researching for weekly youth gatherings with MUNA's chapter President.</li>
                    <li>Planning monthly community events, including barbeques and picnics.</li>
                    <li>Collecting donations and tracking collection records.</li>
                    <li>Mentoring youth through one-on-one meetings about MUNA's mission and membership.</li>
                    <li>Helped renovate MUNA's first Manhattan masjid ahead of opening with 50+ attendees, including the National President.</li>
                </ul>
            </div>

            <div class="entry">
                <div class="entry-title-line">
                    <span class="entry-name no-link">Freelance Developer</span>
                    <span class="entry-separator"> &mdash; </span>
                    <span class="entry-role">Programmer</span>
                </div>
                <div class="entry-date">2021 &ndash; PRESENT</div>
                <ul>
                    <li>Building full Roblox games, from small mechanics to full frameworks.</li>
                    <li>Building custom and optimal Discord bots for servers.</li>
                    <li>Building automation tools for marketplaces and trading platforms.</li>
                    <li>Designing and building full REST APIs for client applications.</li>
                </ul>
            </div>
            </div>
        </section>

        <section>
            <h2>
                <span class="section-arrow">
                    <span class="pulse">></span>
                    <span>Projects</span>
                </span>
            </h2>
            <div class="grid">

            <div class="entry">
                <div class="entry-title-line">
                    <a class="entry-name" href="https://github.com/stafawashere/Allusion" target="_blank">Allusion</a>
                    <span class="entry-separator"> &mdash; </span>
                    <span class="entry-role">Security Research</span>
                </div>
                <div class="entry-date">FEBRUARY 2026</div>
                <p>Reverse-engineered a game's (Rivals) client to find vulnerabilities across anti-cheat, combat, and rendering systems. All findings were disclosed to the Rivals development team before the research was open sourced.</p>
            </div>

            <div class="entry">
                <div class="entry-title-line">
                    <a class="entry-name" href="https://github.com/stafawashere/Disky" target="_blank">Disky</a>
                    <span class="entry-separator"> &mdash; </span>
                    <span class="entry-role">Discord API Wrapper</span>
                </div>
                <div class="entry-date">MAY 2024</div>
                <p>Built a Python wrapper for Discord's API from scratch using raw WebSockets and HTTP requests. The wrapper handles gateway events, session management, and browser fingerprinting without relying on existing Discord libraries.</p>
            </div>

            <div class="entry">
                <div class="entry-title-line">
                    <a class="entry-name" href="https://github.com/stafawashere/ledger" target="_blank">Ledger</a>
                    <span class="entry-separator"> &mdash; </span>
                    <span class="entry-role">Discord Bot</span>
                </div>
                <div class="entry-date">FEBRUARY 2026</div>
                <p>Built a Discord bot for tracking balance, debts, and inventory using slash commands and interactive UI components. Features a modular cog architecture, TinyDB storage, and full audit history with filtering &amp; export.</p>
            </div>
            </div>
        </section>

        <section>
            <h2>
                <span class="section-arrow">
                    <span class="pulse">></span>
                    <span>Education</span>
                </span>
            </h2>

            <div class="entry">
                <div class="entry-title-line">
                    <a class="entry-name" href="https://www.hsartstech.org/" target="_blank">Arts &amp; Technology</a>,
                    <span class="entry-separator"> 66th St Amsterdam NY &mdash; </span>
                    <span class="entry-role">High School</span>
                </div>
                <div class="entry-date">2022 &ndash; 2027</div>
                <p>High school program focused on arts, technology, and programming.</p>
            </div>
        </section>
    </div>
    <script src="js/particles.js"></script>
    <script src="js/glow.js"></script>
</body>
</html>